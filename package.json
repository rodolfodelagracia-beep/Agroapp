:root {
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  line-height: 1.5;
  font-weight: 400;
  color: #142014;
  background: #eef6ef;
  font-synthesis: none;
  text-rendering: optimizeLegibility;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  --bg: #f4f8f3;
  --bg-secondary: rgba(255, 255, 255, 0.72);
  --card: rgba(255, 255, 255, 0.84);
  --card-strong: #ffffff;
  --border: rgba(24, 62, 37, 0.1);
  --text: #14311d;
  --muted: #567061;
  --primary: #2d7c45;
  --primary-strong: #215b33;
  --primary-soft: rgba(45, 124, 69, 0.1);
  --shadow: 0 20px 60px rgba(33, 56, 40, 0.12);
  --radius-xl: 28px;
  --radius-lg: 22px;
  --radius-md: 16px;
}

* {
  box-sizing: border-box;
}

html,
body,
#root {
  min-height: 100%;
  margin: 0;
}

body {
  background:
    radial-gradient(circle at top left, rgba(83, 180, 105, 0.18), transparent 30%),
    radial-gradient(circle at 90% 10%, rgba(198, 159, 71, 0.12), transparent 20%),
    linear-gradient(180deg, #f6faf4 0%, #eef6ef 100%);
  color: var(--text);
}

button,
input {
  font: inherit;
}

button {
  cursor: pointer;
}

.app-shell {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
}

.bg-orb {
  position: absolute;
  filter: blur(80px);
  border-radius: 999px;
  opacity: 0.45;
  pointer-events: none;
}

.orb-1 {
  width: 300px;
  height: 300px;
  background: rgba(81, 171, 100, 0.28);
  top: -80px;
  left: -40px;
}

.orb-2 {
  width: 280px;
  height: 280px;
  background: rgba(212, 191, 111, 0.2);
  right: -80px;
  top: 160px;
}

.bg-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(20, 49, 29, 0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(20, 49, 29, 0.03) 1px, transparent 1px);
  background-size: 36px 36px;
  mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.22), transparent 75%);
  pointer-events: none;
}

.container {
  position: relative;
  z-index: 1;
  width: min(1200px, calc(100% - 32px));
  margin: 0 auto;
  padding: 32px 0 64px;
}

.hero {
  display: grid;
  grid-template-columns: 1.2fr 0.8fr;
  gap: 24px;
  align-items: stretch;
  margin-bottom: 24px;
}

.hero-copy,
.card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow);
  backdrop-filter: blur(16px);
}

.hero-copy {
  padding: 32px;
}

.hero-copy h1 {
  margin: 10px 0 10px;
  font-size: clamp(2rem, 5vw, 3.5rem);
  line-height: 1;
  letter-spacing: -0.04em;
}

.hero-copy p {
  margin: 0;
  color: var(--muted);
  font-size: 1.05rem;
  max-width: 60ch;
}

.eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 8px 12px;
  border-radius: 999px;
  background: rgba(45, 124, 69, 0.12);
  color: var(--primary-strong);
  font-size: 0.9rem;
  font-weight: 700;
}

.hero-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-top: 24px;
}

.hero-badges span {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 10px 14px;
  border-radius: 999px;
  background: var(--card-strong);
  border: 1px solid var(--border);
  font-weight: 600;
}

.hero-panel {
  padding: 28px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.glass {
  background: rgba(255, 255, 255, 0.68);
}

.hero-brand {
  display: flex;
  gap: 16px;
  align-items: center;
}

.brand-mark {
  width: 72px;
  height: 72px;
  border-radius: 22px;
  background: linear-gradient(135deg, #2d7c45 0%, #8ec06f 100%);
  display: grid;
  place-items: center;
  box-shadow: 0 14px 30px rgba(45, 124, 69, 0.22);
}

.brand-mark img {
  width: 52px;
  height: 52px;
}

.hero-brand strong {
  display: block;
  font-size: 1.1rem;
}

.hero-brand p {
  margin: 4px 0 0;
  color: var(--muted);
}

.hero-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
  margin-top: 24px;
}

.hero-stats div {
  padding: 16px;
  border-radius: var(--radius-md);
  background: rgba(255, 255, 255, 0.86);
  border: 1px solid var(--border);
}

.hero-stats span {
  display: block;
  color: var(--muted);
  font-size: 0.9rem;
}

.hero-stats strong {
  display: block;
  margin-top: 6px;
  font-size: 1.1rem;
}

.tabs-wrap {
  padding: 18px;
}

.tabs-header {
  display: flex;
  gap: 12px;
  background: rgba(45, 124, 69, 0.06);
  border-radius: 18px;
  padding: 8px;
  margin-bottom: 20px;
}

.tab-button {
  flex: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  border: 0;
  border-radius: 14px;
  padding: 14px 18px;
  background: transparent;
  color: var(--primary-strong);
  font-weight: 800;
  transition: 0.2s ease;
}

.tab-button.active {
  background: linear-gradient(135deg, #2d7c45 0%, #1f5e33 100%);
  color: white;
  box-shadow: 0 12px 24px rgba(45, 124, 69, 0.25);
}

.panel-grid {
  display: grid;
  grid-template-columns: 1.15fr 0.85fr;
  gap: 18px;
}

.section-card {
  padding: 24px;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 18px;
}

.section-title h2 {
  margin: 0;
  font-size: 1.4rem;
}

.section-title p {
  margin: 2px 0 0;
  color: var(--muted);
}

.section-icon {
  width: 44px;
  height: 44px;
  border-radius: 14px;
  display: grid;
  place-items: center;
  background: rgba(45, 124, 69, 0.1);
  color: var(--primary);
}

.form-grid {
  display: grid;
  gap: 18px;
}

.two-cols {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.subcard {
  padding: 18px;
  border-radius: var(--radius-lg);
  background: var(--card-strong);
  border: 1px solid var(--border);
}

.subcard h3 {
  margin: 0 0 14px;
  font-size: 1rem;
}

label {
  display: grid;
  gap: 8px;
  margin-bottom: 14px;
  font-weight: 600;
}

input[type='number'],
input[type='text'] {
  height: 48px;
  border-radius: 14px;
  border: 1px solid rgba(20, 49, 29, 0.12);
  background: #f9fcf8;
  padding: 0 14px;
  color: var(--text);
  outline: none;
  transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
}

input[type='range'] {
  width: 100%;
  accent-color: var(--primary);
}

input:focus {
  border-color: rgba(45, 124, 69, 0.4);
  box-shadow: 0 0 0 4px rgba(45, 124, 69, 0.12);
}

.inline-note {
  font-size: 0.82rem;
  color: var(--muted);
  font-weight: 500;
}

.primary-button {
  width: 100%;
  min-height: 50px;
  border: 0;
  border-radius: 16px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  background: linear-gradient(135deg, #2d7c45 0%, #1f5e33 100%);
  color: white;
  font-weight: 800;
  transition: transform 0.18s ease, box-shadow 0.18s ease;
  box-shadow: 0 14px 30px rgba(45, 124, 69, 0.22);
}

.primary-button:hover {
  transform: translateY(-1px);
}

.note-box {
  margin-top: 18px;
  padding: 14px 16px;
  display: flex;
  gap: 10px;
  align-items: flex-start;
  border-radius: 16px;
  background: rgba(45, 124, 69, 0.08);
  color: var(--primary-strong);
}

.note-box p {
  margin: 0;
}

.result-panel {
  display: flex;
  flex-direction: column;
}

.metrics-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14px;
}

.metric-card {
  padding: 16px;
  border-radius: 18px;
  background: var(--card-strong);
  border: 1px solid var(--border);
}

.metric-head {
  display: flex;
  align-items: center;
  gap: 10px;
  color: var(--muted);
  font-weight: 700;
  margin-bottom: 10px;
}

.metric-icon {
  width: 32px;
  height: 32px;
  border-radius: 12px;
  display: grid;
  place-items: center;
  background: rgba(45, 124, 69, 0.08);
  color: var(--primary);
}

.metric-card strong {
  display: block;
  font-size: 1.3rem;
  line-height: 1.2;
}

.metric-card small {
  display: block;
  margin-top: 6px;
  color: var(--muted);
}

.status-banner {
  margin-top: 16px;
  border-radius: 18px;
  padding: 16px;
  display: flex;
  gap: 12px;
  align-items: flex-start;
  border: 1px solid transparent;
}

.status-banner strong {
  display: block;
  margin-bottom: 4px;
}

.status-banner p {
  margin: 0;
  color: inherit;
}

.status-banner.success {
  background: rgba(38, 157, 90, 0.12);
  color: #1d6a3d;
  border-color: rgba(38, 157, 90, 0.18);
}

.status-banner.warning {
  background: rgba(196, 135, 46, 0.12);
  color: #87591b;
  border-color: rgba(196, 135, 46, 0.18);
}

.status-banner.danger {
  background: rgba(192, 76, 76, 0.12);
  color: #9d3434;
  border-color: rgba(192, 76, 76, 0.18);
}

.empty-state {
  min-height: 180px;
  border: 1px dashed rgba(20, 49, 29, 0.15);
  border-radius: 20px;
  display: grid;
  place-items: center;
  text-align: center;
  color: var(--muted);
}

.toggle-group {
  display: inline-grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 8px;
  padding: 6px;
  border-radius: 16px;
  background: rgba(45, 124, 69, 0.06);
  margin-bottom: 14px;
}

.toggle {
  min-width: 120px;
  border: 0;
  border-radius: 12px;
  padding: 10px 12px;
  font-weight: 700;
  background: transparent;
  color: var(--primary-strong);
}

.toggle.active {
  background: white;
  box-shadow: 0 8px 18px rgba(24, 62, 37, 0.08);
}

.range-value {
  display: inline-block;
  margin-top: 4px;
  color: var(--muted);
  font-size: 0.95rem;
}

@media (max-width: 980px) {
  .hero,
  .panel-grid,
  .two-cols {
    grid-template-columns: 1fr;
  }

  .hero-copy,
  .hero-panel,
  .section-card {
    padding: 22px;
  }
}

@media (max-width: 640px) {
  .container {
    width: min(100% - 20px, 1200px);
    padding-top: 20px;
  }

  .tabs-header,
  .metrics-grid,
  .hero-stats {
    grid-template-columns: 1fr;
  }

  .tabs-header {
    display: grid;
  }

  .hero-badges {
    gap: 8px;
  }

  .hero-badges span,
  .tab-button,
  .primary-button {
    font-size: 0.95rem;
  }
}
